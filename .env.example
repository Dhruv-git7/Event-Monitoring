# FILE: .env.example
# PostgreSQL connection string used by backend services
PG_URL=postgresql://platform:platform@localhost:5432/platform
# Redis connection string used for pub/sub and cache
REDIS_URL=redis://localhost:6379
# Kafka broker list for producers and consumers
KAFKA_BROKERS=localhost:9092
# Kafka topic for raw agent metric payloads
RAW_METRICS_TOPIC=raw-metrics
# ClickHouse HTTP endpoint
CLICKHOUSE_URL=http://localhost:8123
# ClickHouse username
CLICKHOUSE_USER=default
# ClickHouse password
CLICKHOUSE_PASSWORD=
# ClickHouse database name
CLICKHOUSE_DATABASE=platform
# Auth API port
AUTH_API_PORT=4002
# Agent API port
AGENT_API_PORT=4000
# WebSocket gateway port
WS_GATEWAY_PORT=4001
# Dashboard URL allowed by CORS
DASHBOARD_ORIGIN=http://localhost:3000
# JWT signing secret for access tokens
JWT_SECRET=replace-with-long-random-secret
# Cookie signing secret
COOKIE_SECRET=replace-with-long-random-secret
# Whether cookies require HTTPS
COOKIE_SECURE=false
# Default tenant id used for registration
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# Public API URL used by the dashboard
NEXT_PUBLIC_API_URL=http://localhost:4002
# Public websocket URL used by the dashboard
NEXT_PUBLIC_WS_URL=http://localhost:4001
# Public agent API URL shown in install commands
NEXT_PUBLIC_AGENT_URL=http://localhost:4000
